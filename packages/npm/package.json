{
  "name": "burner-radar-data",
  "version": "0.1.0",
  "description": "Continuously-updated database of disposable email domains, with a tiny API.",
  "keywords": [
    "email",
    "disposable",
    "burner",
    "tempmail",
    "validation",
    "security",
    "fraud",
    "blocklist"
  ],
  "author": "Manav Doshi",
  "license": "MIT",
  "homepage": "https://github.com/manavdoshi-dev/burner-radar",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/manavdoshi-dev/burner-radar.git",
    "directory": "packages/npm"
  },
  "bugs": {
    "url": "https://github.com/manavdoshi-dev/burner-radar/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "node --test test/*.test.mjs"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0"
  }
}
